<Application x:Class="ProjectShortcutDock.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#F7F8FA" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="HoverBrush" Color="#EEF2FF" />
    </Application.Resources>
</Application>
