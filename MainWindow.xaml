<Window x:Class="ProjectShortcutDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProjectShortcutDock"
        Title="Project Shortcuts"
        Width="360"
        Height="260"
        MinWidth="300"
        MinHeight="180"
        SizeToContent="Manual"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        ShowActivated="False"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ShortcutListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ShortcutItemTemplate" DataType="{x:Type local:ShortcutItem}">
            <Border Height="38"
                    Padding="8,4"
                    CornerRadius="6"
                    Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Width="20"
                           Height="20"
                           Source="{Binding IconSource}"
                           Stretch="Uniform" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Path}"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="8"
            Padding="10"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource WindowBrush}">
        <Border.Effect>
            <DropShadowEffect x:Name="ShellShadow" BlurRadius="24" ShadowDepth="3" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               Text="Project Shortcuts"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText"
                               Text="Drop files or folders here"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1"
                        x:Name="SettingsButton"
                        Style="{StaticResource IconButton}"
                        Content="&#xE713;"
                        ToolTip="Settings"
                        Click="ToggleSettings_Click" />
                <Button Grid.Column="2"
                        x:Name="AboutButton"
                        Style="{StaticResource IconButton}"
                        Content="?"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="SemiBold"
                        ToolTip="About"
                        Click="About_Click" />
                <Button Grid.Column="3"
                        x:Name="HideButton"
                        Style="{StaticResource IconButton}"
                        Content="&#xE711;"
                        ToolTip="Hide to tray"
                        Click="Hide_Click" />
            </Grid>

            <Border x:Name="SettingsPanel"
                    Grid.Row="1"
                    Margin="0,10,0,8"
                    Padding="10"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Background="{DynamicResource PanelBrush}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StyleLabel"
                               Grid.Row="0"
                               VerticalAlignment="Center"
                               Text="Style"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox x:Name="ThemeBox"
                              Grid.Row="0"
                              Grid.Column="1"
                              SelectionChanged="ThemeBox_SelectionChanged" />

                    <TextBlock x:Name="WindowModeLabel"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Text="Window mode"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox x:Name="WindowModeBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="WindowModeBox_SelectionChanged" />

                    <TextBlock x:Name="LanguageLabel"
                               Grid.Row="2"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Text="Language"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox x:Name="LanguageBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="LanguageBox_SelectionChanged" />

                    <TextBlock x:Name="TerminalShellLabel"
                               Grid.Row="3"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Text="Shell"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox x:Name="TerminalShellBox"
                              Grid.Row="3"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="TerminalShellBox_SelectionChanged" />

                    <CheckBox x:Name="StartWithWindowsBox"
                              Grid.Row="4"
                              Grid.ColumnSpan="2"
                              Margin="0,10,0,0"
                              Content="Start with Windows"
                              Foreground="{DynamicResource TextBrush}"
                              Checked="StartWithWindowsBox_Changed"
                              Unchecked="StartWithWindowsBox_Changed" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="0,6,0,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CardsHintText"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Button x:Name="AddCardButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="AddCardButton_Click" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ShortcutGroup}">
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        CornerRadius="8"
                                        BorderBrush="{Binding CardBorderBrush}"
                                        Background="{Binding CardBackgroundBrush}"
                                        MouseLeftButtonDown="GroupCard_MouseLeftButtonDown"
                                        AllowDrop="True"
                                        DragEnter="GroupCard_DragEnter"
                                        Drop="GroupCard_Drop">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,8,0"
                                                    CornerRadius="5"
                                                    Background="{Binding CardAccentBrush}" />
                                            <TextBox MinWidth="140"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     FontSize="14"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="GroupName_TextChanged"
                                                     LostFocus="GroupName_LostFocus" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Style="{StaticResource IconButton}"
                                                Content="&#xE74D;"
                                                ToolTip="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DeleteCardToolTipText}"
                                                Click="RemoveGroupButton_Click" />

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,8,0,0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=CardColorLabelText}" />
                                            <ComboBox Width="150"
                                                      Margin="8,0,0,0"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=GroupColorOptions}"
                                                      SelectedValue="{Binding ColorKey, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Key"
                                                      SelectionChanged="GroupColor_SelectionChanged">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type local:CardColorOption}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="12"
                                                                    Height="12"
                                                                    Margin="0,0,8,0"
                                                                    CornerRadius="6"
                                                                    Background="{Binding AccentBrush}" />
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="{Binding DisplayName}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                        <ListBox Grid.Row="2"
                                                 Grid.ColumnSpan="2"
                                                 MinHeight="56"
                                                 Margin="0,10,0,0"
                                                 AllowDrop="True"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemContainerStyle="{StaticResource ShortcutListItemStyle}"
                                                 ItemTemplate="{StaticResource ShortcutItemTemplate}"
                                                 ItemsSource="{Binding Shortcuts}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ContextMenuOpening="ShortcutList_ContextMenuOpening"
                                                 KeyDown="ShortcutList_KeyDown"
                                                 MouseDoubleClick="ShortcutList_MouseDoubleClick"
                                                 PreviewMouseRightButtonDown="ShortcutList_PreviewMouseRightButtonDown"
                                                 DragEnter="GroupCard_DragEnter"
                                                 Drop="GroupCard_Drop" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
