<Window x:Class="ProjectShortcutDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Shortcuts"
        Width="360"
        Height="260"
        MinWidth="280"
        MinHeight="140"
        SizeToContent="Manual"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        ShowActivated="False"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ShortcutListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="8"
            Padding="10"
            CornerRadius="8"
            BorderThickness="1.5"
            BorderBrush="{DynamicResource BorderBrush}"
            Background="{DynamicResource WindowBrush}">
        <Border.Effect>
            <DropShadowEffect x:Name="ShellShadow" BlurRadius="24" ShadowDepth="3" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBox x:Name="GroupNameBox"
                             MinWidth="120"
                             Padding="0"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextBrush}"
                             FontSize="15"
                             FontWeight="SemiBold"
                             IsReadOnly="True"
                             Text="{Binding Group.Name, UpdateSourceTrigger=PropertyChanged}"
                             PreviewMouseLeftButtonDown="GroupNameBox_PreviewMouseLeftButtonDown"
                             TextChanged="GroupNameBox_TextChanged"
                             KeyDown="GroupNameBox_KeyDown"
                             LostFocus="GroupNameBox_LostFocus" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="RenameButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE70F;"
                        Click="RenameButton_Click" />
                <Button Grid.Column="2"
                        x:Name="AddWindowButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe UI"
                        FontSize="16"
                        FontWeight="Bold"
                        Content="+"
                        Click="AddWindowButton_Click" />
                <Button Grid.Column="3"
                        x:Name="RemoveWindowButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe UI"
                        FontSize="16"
                        FontWeight="Bold"
                        Content="−"
                        Click="RemoveWindowButton_Click" />
                <Button Grid.Column="4"
                        x:Name="ColorButton"
                        Style="{StaticResource IconButton}"
                        Click="ColorButton_Click">
                    <Viewbox Width="14"
                             Height="14">
                        <Grid Width="14"
                              Height="14">
                            <Ellipse x:Name="ColorIndicatorFill"
                                     StrokeThickness="0.8" />
                            <Ellipse x:Name="ColorIndicatorOutline"
                                     Fill="Transparent"
                                     StrokeThickness="1.2"
                                     Visibility="Collapsed">
                                <Ellipse.StrokeDashArray>2,1.4</Ellipse.StrokeDashArray>
                            </Ellipse>
                        </Grid>
                    </Viewbox>
                </Button>
                <Button Grid.Column="5"
                        x:Name="SettingsButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE713;"
                        Click="ToggleSettings_Click" />
                <Button Grid.Column="6"
                        x:Name="AboutButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Content="?"
                        Click="About_Click" />
                <Button Grid.Column="7"
                        x:Name="HideButton"
                        Style="{StaticResource IconButton}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE711;"
                        Click="Hide_Click" />
            </Grid>

            <Border x:Name="SettingsPanel"
                    Grid.Row="1"
                    Margin="0,10,0,8"
                    Padding="10"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Background="{DynamicResource PanelBrush}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StyleLabel"
                               Grid.Row="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="Style" />
                    <ComboBox x:Name="ThemeBox"
                              Grid.Row="0"
                              Grid.Column="1"
                              SelectionChanged="ThemeBox_SelectionChanged" />

                    <TextBlock x:Name="WindowModeLabel"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="Window mode" />
                    <ComboBox x:Name="WindowModeBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="WindowModeBox_SelectionChanged" />

                    <TextBlock x:Name="LanguageLabel"
                               Grid.Row="2"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="Language" />
                    <ComboBox x:Name="LanguageBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="LanguageBox_SelectionChanged" />

                    <TextBlock x:Name="TerminalShellLabel"
                               Grid.Row="3"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"
                               Text="Shell" />
                    <ComboBox x:Name="TerminalShellBox"
                              Grid.Row="3"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              SelectionChanged="TerminalShellBox_SelectionChanged" />

                    <CheckBox x:Name="StartWithWindowsBox"
                              Grid.Row="4"
                              Grid.ColumnSpan="2"
                              Margin="0,10,0,0"
                              Foreground="{DynamicResource TextBrush}"
                              Content="Start with Windows"
                              Checked="StartWithWindowsBox_Changed"
                              Unchecked="StartWithWindowsBox_Changed" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="0,4,0,0">
                <ListBox x:Name="ShortcutList"
                         ItemsSource="{Binding Shortcuts}"
                         AllowDrop="True"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource ShortcutListItemStyle}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ContextMenuOpening="ShortcutList_ContextMenuOpening"
                         KeyDown="ShortcutList_KeyDown"
                         MouseDoubleClick="ShortcutList_MouseDoubleClick"
                         PreviewMouseRightButtonDown="ShortcutList_PreviewMouseRightButtonDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Height="38"
                                    Padding="8,4"
                                    CornerRadius="6"
                                    Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Width="20"
                                           Height="20"
                                           Source="{Binding IconSource}"
                                           Stretch="Uniform" />
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Path}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="SubtitleText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           IsHitTestVisible="False"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           FontSize="12"
                           Text="Drop files or folders here" />
            </Grid>
        </Grid>
    </Border>
</Window>
